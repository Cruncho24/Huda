supabase/.env
supabase/config.local.toml
supabase/.branches/

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
.vercel
.worktrees

# Dev artifacts not for production
generate-icons.html
App.js

# Claude Code & tooling artifacts
.claude/
.playwright-mcp/
.superpowers/

# Playwright / test artifacts (not app screenshots)
.playwright-mcp/
test-results/

# Docs/plans (internal)
docs/
